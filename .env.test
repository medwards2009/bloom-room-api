# Test environment — loaded only when NODE_ENV=test (e2e harness).
# Committed on purpose: contains no real secrets. The dummy JWT secret is fine
# because AUTH_DEV_MODE=true relaxes the length requirement.
# DB_HOST/PORT/USER/PASSWORD are omitted on purpose — the Joi defaults
# (localhost/5432/bloom/secret) already match docker-compose.

NODE_ENV=test
AUTH_DEV_MODE=true
DB_NAME=bloom_room_test
JWT_SECRET=test-secret-not-for-production
