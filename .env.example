# Server
PORT=8080

# Database (matches docker-compose.yaml)
DB_HOST=localhost
DB_PORT=5432
DB_USER=bloom
DB_PASSWORD=secret
DB_NAME=bloom_room_dev

# Auth — API-issued JWT
# AUTH_DEV_MODE=true relaxes auth for local work: weak JWT_SECRET allowed and
# GOOGLE_CLIENT_IDS optional. Must be false/unset in real environments.
AUTH_DEV_MODE=true
JWT_SECRET=            # >=8 chars in dev mode, >=32 chars otherwise
JWT_EXPIRES_IN=7d

# Google Sign-In: comma-separated list of allowed OAuth client IDs (mobile/web).
# Required unless AUTH_DEV_MODE=true.
GOOGLE_CLIENT_IDS=
